<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules (API 31+). Exclude EncryptedSharedPreferences-backed
   files from both cloud backup and device transfer: the Android Keystore master
   key never leaves the device, so restoring this ciphertext onto a new install
   yields an undecryptable keyset and a launch crash. See TokenStore.kt.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="voiid_auth.xml"/>
        <exclude domain="sharedpref" path="voiid_e2e.xml"/>
        <exclude domain="sharedpref" path="voiid_chat.xml"/>
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__.xml"/>
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="voiid_auth.xml"/>
        <exclude domain="sharedpref" path="voiid_e2e.xml"/>
        <exclude domain="sharedpref" path="voiid_chat.xml"/>
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__.xml"/>
        <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__.xml"/>
    </device-transfer>
</data-extraction-rules>
