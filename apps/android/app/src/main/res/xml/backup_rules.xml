<?xml version="1.0" encoding="utf-8"?><!--
   Backup rules (API < 31). Exclude EncryptedSharedPreferences-backed files:
   the Android Keystore master key is never backed up, so restoring this
   ciphertext onto a new install yields an undecryptable keyset and a launch
   crash (AEADBadTagException). See TokenStore.kt.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="voiid_auth.xml"/>
    <exclude domain="sharedpref" path="voiid_e2e.xml"/>
    <exclude domain="sharedpref" path="voiid_chat.xml"/>
    <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_key_keyset__.xml"/>
    <exclude domain="sharedpref" path="__androidx_security_crypto_encrypted_prefs_value_keyset__.xml"/>
</full-backup-content>
