node_modules/
dist/
.env
.env.*
!.env.example
*.log
.DS_Store
build/
.turbo/
coverage/

# Supabase local artifacts (keep config.toml + migrations symlink tracked)
supabase/.temp/
supabase/.branches/

# Xcode per-user state (not source)
xcuserdata/
*.xcuserstate
DerivedData/

# Android / Gradle build artifacts
.gradle/
apps/android/local.properties

# Firebase config (contains API keys — never commit; add locally / via CI secrets)
GoogleService-Info*.plist
google-services*.json
# Firebase Admin service-account key (server token verification) — never commit
*service-account*.json
firebase-admin*.json
firebase-sa*.json
*firebase*adminsdk*.json

# e2e-core native build outputs (regenerated by packages/e2e-core/build-*.sh;
# canonical bindings live in packages/e2e-core/bindings/). Don't commit the
# multi-MB binaries or the per-app generated glue.
apps/ios/Voiid/Frameworks/Voiid.xcframework/
apps/ios/Voiid/Voiid/E2E/voiid.swift
apps/android/app/src/main/jniLibs/
apps/android/app/src/main/java/uniffi/

# Signing / keystores
*.keystore
*.jks
*.p12
*.mobileprovision
