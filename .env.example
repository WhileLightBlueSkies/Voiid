# VOIID — environment template. Copy to .env (gitignored). Separate values per env (dev/staging/prod).
# NEVER commit real secrets. In CI these come from GitHub Secrets (Section 7.7).

NODE_ENV=development

# --- API service ---
API_PORT=4000

# --- WebSocket service ---
WS_PORT=4001

# --- Database (Supabase = Postgres host ONLY; not Supabase Auth, not Supabase Realtime) ---
# Use plain Postgres in critical paths so swapping host = connection-string change.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voiid

# --- Redis (presence, pub/sub, typing, rate-limit, cache) ---
REDIS_URL=redis://localhost:6379

# --- Auth (OURS — Firebase only sends OTP SMS) ---
JWT_SECRET=change-me-in-every-env
JWT_EXPIRY=30d

# --- SMS / OTP provider (swappable interface: firebase | msg91 | twilio) ---
SMS_PROVIDER=firebase
FIREBASE_CONFIG=

# --- Media (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=voiid-media

# --- Ops ---
SENTRY_DSN=
