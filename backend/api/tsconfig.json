{
  "compilerOptions": {
    "target": "ES2022",
    // CommonJS Node project (no "type":"module") — emits `require()` so
    // `node dist/index.js` works. "node16" resolution would force ESM emit +
    // .js import extensions across the codebase, so we keep "node" and silence
    // its (cosmetic) deprecation for the pinned build compiler (TS 5.9).
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
